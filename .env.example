# Copy this file to .env and fill in your key (do not commit .env)
VITE_GOOGLE_MAPS_API_KEY=

# Nearby counseling centers API (API Gateway stage URL, no trailing slash)
# VITE_COUNSELING_API_BASE=https://xxxx.execute-api.ap-southeast-2.amazonaws.com/dev
# Optional search radius in meters (default 90000 so metro users still see CBD listings)
# VITE_COUNSELING_SEARCH_RADIUS_METERS=90000
# Local dev: Vite proxies /__counseling/* to this base to avoid CORS. Production still needs CORS on API Gateway.
